DOMAIN-KEYWORD,ytimg
DOMAIN-KEYWORD,googlevideo
DOMAIN-KEYWORD,gstatic
DOMAIN-KEYWORD,googleapis
DOMAIN-KEYWORD,googleusercontent
DOMAIN-KEYWORD,ggpht
DOMAIN-KEYWORD,gvt1
DOMAIN-KEYWORD,gvt2
DOMAIN-SUFFIX,youtu.be
